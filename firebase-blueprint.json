{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "A company (tenant) in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" },
        "settings": { "$ref": "Settings" }
      },
      "required": ["id", "name", "active"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "A support ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "client": { "type": "string" },
        "status": { "type": "string", "enum": ["Aberto", "Em Andamento", "Aguardando Cliente", "Aguardando Terceiros", "Resolvido"] },
        "category": { "type": "string" },
        "responsible": { "type": "string" },
        "sla": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "author": { "type": "string" },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["companyId", "title", "client", "status", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Application settings per company",
      "type": "object",
      "properties": {
        "webhookUrl": { "type": "string" },
        "clientLogos": { "type": "object" },
        "clientResponsibles": { "type": "object" },
        "customClients": { "type": "array", "items": { "type": "string" } },
        "customCategories": { "type": "array", "items": { "type": "string" } }
      }
    },
    "User": {
      "title": "User",
      "description": "A user of the system",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "companyId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "admin", "user", "client", "pending"] },
        "associatedClient": { "type": "string" }
      },
      "required": ["uid", "companyId", "email"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "A shift schedule for an analyst",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "analyst": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "shift": { "type": "string" }
      },
      "required": ["companyId", "analyst", "date", "shift"]
    }
  },
  "firestore": {
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Collection of companies"
    },
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Collection of support tickets"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users"
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Collection of analyst schedules"
    }
  }
}

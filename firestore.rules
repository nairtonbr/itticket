rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: companies
    // Document ID: companyId
    // Fields:
    //   - id: string
    //   - name: string
    //   - active: boolean
    //   - settings: map
    //
    // Collection: tickets
    // Document ID: auto-generated
    // Fields:
    //   - companyId: string (required)
    //   ...
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - companyId: string (required)
    //   - role: string (superadmin|admin|user|client|pending)
    //   ...
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function userExists() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'superadmin' || 
         request.auth.token.email == "nairtonbraga00@gmail.com");
    }

    function hasRole(role) {
      return userExists() && getUserData().role == role;
    }

    function isAdmin() {
      return isSuperAdmin() || hasRole('admin');
    }

    function isUser() {
      return hasRole('user');
    }

    function isClient() {
      return hasRole('client');
    }

    function getCompanyId() {
      return getUserData().companyId;
    }

    function belongsToCompany(companyId) {
      return isSuperAdmin() || (isAuthenticated() && getCompanyId() == companyId);
    }

    function resourceBelongsToUserCompany() {
      return belongsToCompany(resource.data.companyId);
    }

    function requestBelongsToUserCompany() {
      return belongsToCompany(request.resource.data.companyId);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /companies/{companyId} {
      // Superadmins can do anything
      // Admins/Users/Clients can read their own company
      allow read: if belongsToCompany(companyId);
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if (isAuthenticated() && request.auth.uid == userId) || isSuperAdmin() || (isAdmin() && getUserData().companyId == get(/databases/$(database)/documents/users/$(userId)).data.companyId);
      
      allow create: if isAuthenticated() && 
                    (isSuperAdmin() || (request.auth.uid == userId && request.resource.data.role == 'pending'));
      
      allow update: if isAuthenticated() && 
                    (isSuperAdmin() || 
                     (isAdmin() && getCompanyId() == resource.data.companyId && request.resource.data.role != 'superadmin') || 
                     (request.auth.uid == userId && request.resource.data.role == resource.data.role));
    }

    match /tickets/{ticketId} {
      allow read: if isSuperAdmin() || (resourceBelongsToUserCompany() && (isAdmin() || isUser() || (isClient() && resource.data.client == getUserData().associatedClient)));
      
      allow create: if isAuthenticated() && requestBelongsToUserCompany() && 
                    (isAdmin() || isUser() || (isClient() && request.resource.data.client == getUserData().associatedClient));
      
      allow update: if isAuthenticated() && resourceBelongsToUserCompany() && requestBelongsToUserCompany() &&
                    (isAdmin() || isUser() || (isClient() && resource.data.client == getUserData().associatedClient));
      
      allow delete: if isSuperAdmin() || (isAdmin() && resourceBelongsToUserCompany());
    }

    match /schedules/{scheduleId} {
      allow read: if isSuperAdmin() || resourceBelongsToUserCompany();
      allow write: if isSuperAdmin() || (isAdmin() && requestBelongsToUserCompany());
    }
  }
}
